{
  "name": "browstack",
  "version": "0.1.0",
  "description": "Browser + Substack — turn your own browsing history into a beautifully designed, privacy-first personal weekly digest, delivered to your inbox.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/ensure-config.mjs",
    "ingest": "tsx src/cli.ts ingest",
    "stats": "tsx src/cli.ts stats",
    "reclassify": "tsx src/cli.ts reclassify",
    "serve": "tsx src/server.ts",
    "preview": "tsx src/render/preview.ts",
    "enrich": "tsx src/cli.ts enrich",
    "cover": "tsx src/render/cover.ts",
    "email": "tsx src/render/email.ts",
    "send": "tsx src/render/email.ts && tsx src/render/send.ts",
    "weekly": "node scripts/weekly.mjs",
    "schedule:weekly": "node scripts/install-weekly.mjs",
    "build:ext": "esbuild extension/src/content.ts extension/src/background.ts extension/src/popup.ts --bundle --outdir=extension/dist --format=iife --target=chrome120 --log-level=warning",
    "typecheck": "tsc --noEmit && tsc -p extension --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.10.0",
    "jsdom": "^27.0.1",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/chrome": "^0.0.280",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.17.0",
    "@types/nodemailer": "^8.0.1",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
